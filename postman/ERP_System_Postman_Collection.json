    {
      "name": "1. Create User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = Date.now();",
              "pm.collectionVariables.set('userEmail', `student_${suffix}@erp.local`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('User response contains id and email', function () {",
              "  pm.expect(json).to.have.property('id');",
              "  pm.expect(json).to.have.property('email');",
              "});",
              "",
              "pm.test('Created email matches generated email', function () {",
              "  pm.expect(json.email).to.eql(pm.collectionVariables.get('userEmail'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"role\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        }
      }
    },
